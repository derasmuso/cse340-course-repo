<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>
        <h2>Upcoming Service Projects</h2>
        <ul>
            <% projects.forEach(project=> { %>
                <li>
                    <%= new Date(project.service_project_date).toLocaleDateString('en-US', { year: 'numeric' ,
                        month: 'long' , day: 'numeric' }) %>:
                        <a href="/project/<%= project.service_project_id %>">
                            <%= project.service_project_title %>
                        </a>
                        (<a href="/organization/<%= project.organization_id %>">
                            <%= project.organization_name %>
                        </a>)
                </li>
                <% }) %>
        </ul>
        <p><a href="/new-project">Add a New Service Project</a></p>
    </main>
    <%- include('partials/footer') %>